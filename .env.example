# ─────────────────────────────────────────────────────────────
# Supabase (ONE shared Cloud project used by BOTH apps)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser. Used only in server actions
# (user creation, password reset, legacy import).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ระบบขอที่จอดรถ ป.ป.ช.

# Internal synthetic-email domain for username login.
# Username "admin" becomes "admin@nacc.local" before Supabase Auth.
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=nacc.local

# ─────────────────────────────────────────────────────────────
# Legacy importer (optional — only needed to run pnpm import:legacy)
# Postgres connection string for the shared Supabase project.
# Found in Supabase dashboard → Project Settings → Database → Connection string.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres
