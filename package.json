{
  "name": "nacc-parking-request-system",
  "version": "0.1.0",
  "private": true,
  "description": "NACC-style Thai parking request management system (Admin + User apps on Next.js + Supabase)",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=@nacc/admin",
    "dev:user": "turbo run dev --filter=@nacc/user",
    "dev:reset": "rimraf apps/admin/.next apps/user/.next && turbo run dev",
    "clean:next": "rimraf apps/admin/.next apps/user/.next",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "supabase": "supabase",
    "db:link": "supabase link",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset --linked",
    "db:seed": "supabase db push && echo 'Run seed via SQL editor or: psql $DATABASE_URL -f supabase/seed.sql'",
    "db:types": "supabase gen types typescript --linked --schema public > packages/types/src/database.types.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:test": "tsx scripts/seed-test.ts",
    "import:legacy": "tsx scripts/import-legacy.ts",
    "push:sheet": "tsx scripts/push-to-sheet.ts",
    "watch:sheet": "tsx scripts/watch-and-sync.ts"
  },
  "devDependencies": {
    "@nacc/types": "workspace:*",
    "@nacc/utils": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "supabase": "^1.226.4",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
